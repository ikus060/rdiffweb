#!/usr/bin/make -f

include /usr/share/dpkg/pkg-info.mk

export SETUPTOOLS_SCM_PRETEND_VERSION_FOR_RDIFFWEB := $(DEB_VERSION_UPSTREAM)

# Default to running selenium tests
export SELENIUM_TEST ?= 1

# Force use of pyproject.toml
export PYBUILD_SYSTEM=pyproject

PYTHON3_DEFAULT := $(shell py3versions -vd)

%:
	dh $@ --buildsystem=pybuild --test-tox

execute_before_dh_auto_build:
	@echo "Checking for Ubuntu Jammy..."
	@if grep -q "Ubuntu 22.04" /etc/os-release; then \
		echo "Running on Ubuntu Jammy: Installing setuptools>=66,<=68"; \
		pip install "setuptools>=66,<=68"; \
	fi

override_dh_auto_test:
	# For testing, we need a timezone
ifeq ($(SELENIUM_TEST),1)
    TZ=UTC xvfb-run dh_auto_test
else
    TZ=UTC dh_auto_test
endif

execute_after_dh_auto_install:
# Compile locale
	for pofile in debian/rdiffweb/usr/lib/python$(PYTHON3_DEFAULT)/dist-packages/rdiffweb/locales/*/LC_MESSAGES/*.po ; do \
		mofile=`echo $$pofile | sed -e "s/\.po/\.mo/g"`; \
		msgfmt $$pofile -o $$mofile; \
	done
# Remove tests files
	find debian/rdiffweb/usr/lib/python$(PYTHON3_DEFAULT)/dist-packages/rdiffweb -type d -name "tests" -exec rm -rf {} +

# Generate bash-completions with shtab
execute_after_dh_bash-completion:
	PYTHONPATH=debian/rdiffweb/usr/lib/python$(PYTHON3_DEFAULT)/dist-packages:$(PYTHONPATH) \
	shtab --shell=bash -u rdiffweb.core.config.get_parser --error-unimportable --prog rdiffweb \
		> debian/rdiffweb.bash-completion

# Generate man page from argparse
execute_after_dh_installman:
	mkdir -p debian/rdiffweb/usr/share/man/man1
	PYTHONPATH=debian/rdiffweb/usr/lib/python$(PYTHON3_DEFAULT)/dist-packages:$(PYTHONPATH) \
	argparse-manpage --module rdiffweb.core.config --function get_parser \
		--version "$(DEB_VERSION_UPSTREAM)" \
		--output debian/rdiffweb/usr/share/man/man1/rdiffweb.1

execute_before_dh_auto_clean:
	rm -rf *.egg-info
	rm -rf debian/rdiffweb.bash-completion

# Generate orig.tar.gz
gentarball:
	git archive --format=tar HEAD --prefix=$(DEB_SOURCE)-$(DEB_VERSION_UPSTREAM)/ | gzip -9 > ../$(DEB_SOURCE)_$(DEB_VERSION_UPSTREAM).orig.tar.gz
	mk-origtargz --compression gzip ../$(DEB_SOURCE)_$(DEB_VERSION_UPSTREAM).orig.tar.gz
